# ============================================
# Supabase 설정
# ============================================
# Supabase 프로젝트 URL (프로젝트 대시보드 > Settings > API에서 확인)
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Supabase Anon/Public 키 (클라이언트에서 사용 가능)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role 키 (서버 전용, 절대 클라이언트에 노출하지 마세요)
# RLS를 우회하고 관리자 권한으로 데이터베이스에 접근합니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AI 서비스
# ============================================
# Google Gemini API 키 (Google AI Studio에서 발급)
# https://ai.google.dev/
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Anthropic Claude API 키 (사주/천지인/궁합/관상/손금/풍수 분석용)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API 키 (GPT-4 Vision API용, 선택사항)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# ============================================
# 결제 시스템 (Toss Payments)
# ============================================
# Toss Payments 클라이언트 키 (클라이언트에서 사용)
# https://developers.tosspayments.com/
NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=your-toss-client-key

# Toss Payments Secret 키 (서버 전용, 절대 클라이언트에 노출하지 마세요)
TOSS_PAYMENTS_SECRET_KEY=your-toss-secret-key

# Toss Payments 웹훅 검증용 Secret 키
TOSS_SECRET_KEY=your-toss-secret-key

# ============================================
# 애플리케이션 설정
# ============================================
# 애플리케이션 URL (개발: http://localhost:3000, 프로덕션: https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# ============================================
# Solapi (카카오 알림톡)
# ============================================
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER_PHONE=01012345678
# 카카오 채널 ID (Solapi 콘솔 > 카카오 채널 관리에서 확인)
SOLAPI_PFID=KA01PF...
