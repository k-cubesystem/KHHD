{
  "id": "compatibility_viral_sharing",
  "name": "궁합 바이럴 스킬 (소셜 공유 최적화)",
  "version": "1.0.0",
  "description": "궁합 결과를 SNS에 공유할 때 최적화된 OG 이미지와 메시지를 자동 생성하여 바이럴 확산을 유도합니다.",
  "category": "growth-marketing",
  "author": "Claude",
  "created": "2026-01-24",

  "concept": {
    "goal": "궁합 결과 공유 → 친구 유입 → 가입 증가",
    "hook": "나와 [친구이름]의 궁합은? 😱",
    "cta": "지금 바로 확인하기 >"
  },

  "features": [
    "OG 이미지 자동 생성 (궁합 점수 + 두 사람 이름)",
    "SNS별 최적화 메시지 (카톡, 인스타, 페북)",
    "초대 링크 생성 (추천인 추적)",
    "공유 리워드 (부적 1개)",
    "바이럴 리더보드 (가장 많이 공유된 궁합)"
  ],

  "workflow": {
    "steps": [
      {
        "id": "step1_compatibility_result",
        "name": "궁합 분석 완료",
        "trigger": "두 사람의 궁합 점수 계산 후"
      },
      {
        "id": "step2_og_image_generation",
        "name": "OG 이미지 생성",
        "description": "Canvas API로 맞춤형 이미지를 생성합니다.",
        "design": {
          "background": "그라데이션 (점수별 색상)",
          "layout": [
            "상단: '해화당 AI 궁합 분석'",
            "중앙: '[A] ❤️ [B]'",
            "점수: 큰 폰트 (예: 89점)",
            "타입: '천생연분' 뱃지",
            "하단: '해화당에서 확인하기 →'"
          ],
          "size": "1200x630px (OG 표준)"
        },
        "tech": "node-canvas 또는 Vercel OG Image"
      },
      {
        "id": "step3_message_generation",
        "name": "공유 메시지 생성",
        "templates": {
          "kakao": "🔮 [A]님과 [B]님의 궁합은 [점수]점! [타입] 관계래요 😳 나도 궁합 보러가기 >",
          "instagram": "💫 해화당에서 우리 궁합 봤는데 대박 😱 #해화당 #궁합 #사주",
          "facebook": "[A] & [B] 궁합 점수 공개! 🎯 결과는 [점수]점 ([타입])"
        }
      },
      {
        "id": "step4_invite_link",
        "name": "초대 링크 생성",
        "format": "https://haehwadang.com/invite/[inviteCode]?from=[userId]",
        "tracking": "추천인 ID 저장하여 가입 시 리워드"
      },
      {
        "id": "step5_share_action",
        "name": "공유 액션",
        "platforms": [
          {
            "name": "카카오톡",
            "sdk": "Kakao JavaScript SDK",
            "type": "템플릿 메시지"
          },
          {
            "name": "인스타그램",
            "method": "스토리 공유 (이미지 + 링크 스티커)"
          },
          {
            "name": "페이스북",
            "sdk": "Facebook SDK",
            "type": "피드 공유"
          },
          {
            "name": "링크 복사",
            "method": "클립보드 복사"
          }
        ]
      },
      {
        "id": "step6_reward",
        "name": "공유 리워드",
        "reward": "부적 1개 즉시 지급",
        "condition": "최초 1회 공유 시"
      }
    ]
  },

  "ogImageAPI": {
    "endpoint": "/api/og/compatibility",
    "method": "GET",
    "params": {
      "name1": "string",
      "name2": "string",
      "score": "number",
      "type": "string"
    },
    "response": "image/png"
  },

  "ui": {
    "shareModal": {
      "trigger": "궁합 결과 페이지 '공유하기' 버튼",
      "layout": [
        "상단: OG 이미지 미리보기",
        "중간: SNS 버튼 (카톡/인스타/페북/링크)",
        "하단: 리워드 안내 (부적 1개 획득!)"
      ]
    },
    "successFeedback": {
      "message": "공유 완료! 부적 1개를 받았어요 🎁",
      "animation": "Confetti"
    }
  },

  "analytics": {
    "track": [
      "공유 버튼 클릭 수",
      "플랫폼별 공유 수",
      "초대 링크 클릭 수",
      "전환율 (공유 → 가입)"
    ],
    "goal": "K-factor > 1.0 (바이럴 루프)"
  },

  "cost": {
    "userCost": "무료 (오히려 리워드 지급)",
    "systemCost": "이미지 생성 비용 (무시 가능)"
  },

  "dependencies": {
    "libraries": [
      "@vercel/og (OG 이미지 생성)",
      "react-share (SNS 공유 컴포넌트)"
    ],
    "sdks": [
      "Kakao JavaScript SDK",
      "Facebook SDK for JavaScript"
    ]
  },

  "futureEnhancements": [
    "AI 생성 궁합 포스터 (더 고급스러운 디자인)",
    "동영상 생성 (Luma AI)",
    "공유자 리더보드 (가장 많이 공유한 사람)",
    "친구 초대 이벤트 (10명 초대 시 프리미엄 무료)"
  ]
}
